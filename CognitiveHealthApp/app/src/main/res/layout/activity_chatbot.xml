<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F5F7FA"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AI Assistant 🤖"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1E3A5F"
        android:layout_marginBottom="15dp" />

    <TextView
        android:id="@+id/chatOutput"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Bot: Hello! Ask me about memory, stress, routine, exercise, sleep, or doctor appointment."
        android:textSize="16sp"
        android:textColor="#263238"
        android:background="#FFFFFF"
        android:padding="15dp"
        android:gravity="top"
        android:scrollbars="vertical"
        android:layout_marginBottom="15dp" />

    <EditText
        android:id="@+id/chatInput"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Ask something like 'memory tips'"
        android:inputType="text"
        android:background="#FFFFFF"
        android:padding="14dp" />

    <Button
        android:id="@+id/sendBtn"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Send"
        android:layout_marginTop="10dp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2F80ED" />
</LinearLayout>
