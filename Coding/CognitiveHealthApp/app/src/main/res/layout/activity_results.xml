<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Exercise Completed"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1E3A5F"
            android:gravity="center"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/resultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="You scored 2 / 3"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#263238"
            android:gravity="center"
            android:background="#FFFFFF"
            android:padding="28dp"
            android:layout_marginBottom="18dp" />

        <TextView
            android:id="@+id/feedbackText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Good effort! Continue daily brain exercises to improve memory and focus."
            android:textSize="17sp"
            android:textColor="#5F6F7A"
            android:gravity="center"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:lineSpacingExtra="5dp"
            android:layout_marginBottom="22dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Recommended Next Activities"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1E3A5F"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Try one word quiz\n• Complete a 5-minute meditation\n• Practice one maths puzzle tomorrow"
            android:textSize="16sp"
            android:textColor="#263238"
            android:background="#FFFFFF"
            android:padding="18dp"
            android:lineSpacingExtra="6dp" />

    </LinearLayout>
</ScrollView>